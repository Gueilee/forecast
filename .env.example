# ── Desenvolvimento local (SQLite) ─────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ── Auth ────────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="gere-um-secret-forte-aqui"
NEXTAUTH_URL="http://localhost:3000"

# ── Turso — banco de produção (app.turso.tech) ──────────────────────────────────
TURSO_DATABASE_URL="libsql://forecast-gueilee.aws-us-east-1.turso.io"
TURSO_AUTH_TOKEN="seu-token-aqui"

# ── Oracle / Conexos (requer IP fixo do servidor whitelistado) ──────────────────
CONEXOS_USER="CNXBI_VENDEMMIA"
CONEXOS_PASSWORD=""
CONEXOS_HOST="rds-vendemmia-uydge.conexos.cloud"
CONEXOS_PORT="15003"
CONEXOS_SERVICE="CONEXOS"

# ── E-mail (Nodemailer SMTP) ────────────────────────────────────────────────────
# Se MAILER_DSN ou EMAIL_HOST não for definido, e-mails são apenas logados no console (modo dev)
# MAILER_DSN=smtp://smtp.azurecomm.net:587?encryption=tls&username=seu_usuario&password=sua_senha
# MAILER_FROM=naoresponda@vendemmia.com.br

EMAIL_HOST="smtp.office365.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="naoresponda@vendemmia.com.br"
EMAIL_PASS="sua-senha-smtp"
EMAIL_FROM="Forecast Vendemmia <naoresponda@vendemmia.com.br>"

# ── Docker / Azure ──────────────────────────────────────────────────────────────
APP_PORT=3000
SYNC_HOURS=6,18
TAG=latest
